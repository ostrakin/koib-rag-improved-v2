# ════════════════ KOIB RAG — .env для VK Long Poll бота ════════════════
# Копируется из этого файла в .env. Бот обслуживает запросы по ГОТОВОМУ индексу
# из ./output (переносится с индексатора). Переиндексации нет.
KOIB_VERSION=4.12.0

# Путь к загруженному индексу (по умолчанию ./output рядом с проектом)
# KOIB_OUTPUT_DIR=./output

# ┌─ ⚠ КРИТИЧНО: модель и префиксы ДОЛЖНЫ совпадать с теми, что были при ─┐
# │  индексации, иначе вектор запроса не совпадёт с индексом и поиск      │
# │  деградирует. Сверяется автоматически по манифесту при старте.        │
# └──────────────────────────────────────────────────────────────────────┘
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
PASSAGE_PREFIX=passage:
QUERY_PREFIX=query:
INDEXING_DEVICE=cpu

# ── Генерация: GigaChat (удалённый API — почти не ест локальную память) ──
LLM_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=            # ← Base64-ключ авторизации (Authorization key) из кабинета GigaChat
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false
GIGACHAT_MAX_TOKENS=1536
GIGACHAT_TIMEOUT=45

# ── Усиленный системный промпт VK-бота (src/vk_prompt.py). false = базовый ──
KOIB_VK_CUSTOM_PROMPT=true

# ── Гибридный поиск (как на сервере) ──
VECTOR_SEARCH_K=15
BM25_SEARCH_K=10
FINAL_TOP_K=6
HYBRID_ALPHA=0.6
BM25_USE_LEMMATIZATION=true
BM25_USE_STOPWORDS=true

# ── Память на 2 ГБ: реранкер и HyDE держим выключенными ──
USE_RERANKER=false
USE_ONNX_RERANKER=false
USE_HYDE=false
MAX_CONCURRENT_GENERATIONS=2

# ── Дружелюбный пересказ ответа (второй проход LLM) ──
ANSWER_REFINE_ENABLED=true
ANSWER_REFINE_TEMPERATURE=0.35
ANSWER_REFINE_MAX_TOKENS=1024

# ── Отправка релевантных рисунков из документации ──
SEND_FIGURES_ENABLED=true
MAX_FIGURES_PER_ANSWER=2

# ════════════════ VK Bots Long Poll ════════════════
# Токен сообщества с правами «Сообщения» + «Управление» (scope: messages, manage).
# Создаётся в: Сообщество → Управление → Работа с API → Ключи доступа.
VK_ACCESS_TOKEN=
VK_GROUP_ID=                     # числовой id сообщества (без знака «-»)
VK_API_VERSION=5.131

# Long Poll опрашивает сервер VK; wait — длительность ожидания событий, сек (≤25).
VK_LONGPOLL_WAIT=25

# ── Лимиты и поведение бота ──
VK_RATE_LIMIT_PER_MINUTE=20          # на одного пользователя
VK_GLOBAL_RATE_LIMIT_PER_MINUTE=120  # суммарно
VK_MAX_INCOMING_CHARS=1500
VK_MAX_OUTGOING_CHARS=3900
VK_SEND_TYPING=true
VK_REPLY_IN_GROUP_CHATS=false        # отвечать в беседах (по умолчанию только ЛС)
VK_BOT_MENTION_ALIASES=коиб,koib
VK_ADMIN_IDS=                        # id админов через запятую (для /health)

# Callback-специфичные переменные (VK_CONFIRM_CODE, VK_SECRET_KEY) для Long Poll
# НЕ нужны — оставьте пустыми.

# ── OCR-предобработка: тяжёлые шаги только на индексации, на боте — выкл ──
OCR_PREPROCESSING_ENABLED=true
OCR_DEEP_CLEAN=false
OCR_DROP_GARBAGE_LINES=false
OCR_SPLIT_GLUED_WORDS=false

# ── Фильтр модели КОИБ ──
MODEL_FILTER_STRICT=true
MODEL_STRICT_MIN_EXACT=2

# ── Расширение контекста ──
CONTEXT_EXPANSION_ENABLED=true
CONTEXT_EXPANSION_WINDOW=1
CONTEXT_EXPANSION_MAX_CHARS=2400
