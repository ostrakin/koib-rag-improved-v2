# ════════════════════════ KOIB RAG — .env СЕРВЕРНОЙ сборки ════════════════════════
# Скопируйте в .env и заполните секреты.  Сборка только обслуживает запросы:
# готовый индекс лежит в ./output (загружается отдельно), переиндексации нет.
KOIB_VERSION=4.12.0

# Путь к загруженному индексу (по умолчанию ./output рядом с проектом)
# KOIB_OUTPUT_DIR=./output

# ┌───────────────────────────────────────────────────────────────────────────┐
# │ ⚠ КРИТИЧНО: модель и префиксы ДОЛЖНЫ совпадать с теми, что были при         │
# │   индексации. Иначе вектор запроса не совпадёт с векторами индекса и        │
# │   качество поиска резко упадёт. Менять здесь — только если меняли при сборке.│
# └───────────────────────────────────────────────────────────────────────────┘
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
PASSAGE_PREFIX=passage:
QUERY_PREFIX=query:
INDEXING_DEVICE=cpu

# ── Генерация: GigaChat (удалённый API, локальной памяти почти не ест) ──
LLM_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=            # ← вставьте Base64-ключ авторизации
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false
GIGACHAT_MAX_TOKENS=1536
GIGACHAT_TIMEOUT=45

# ── Гибридный поиск ──
VECTOR_SEARCH_K=15
BM25_SEARCH_K=10
FINAL_TOP_K=6
HYBRID_ALPHA=0.6
BM25_USE_LEMMATIZATION=true
BM25_USE_STOPWORDS=true

# ── ⚠ Память: на 2 ГБ держите ВЫКЛЮЧЕННЫМИ — каждый грузит ещё одну torch-модель ──
USE_RERANKER=false               # CrossEncoder = +сотни МБ ОЗУ → риск OOM
USE_ONNX_RERANKER=false
USE_HYDE=false                   # лишний вызов LLM на каждый запрос

# ── Лимит одновременных генераций (LLM удалённый, поэтому памяти не добавляет) ──
MAX_CONCURRENT_GENERATIONS=2

# ── OCR-предобработка: тяжёлые шаги — только на индексации, на сервере ВЫКЛ ──
OCR_PREPROCESSING_ENABLED=true   # лёгкие замены/гомоглифы — дёшево, оставляем
OCR_DEEP_CLEAN=false
OCR_DROP_GARBAGE_LINES=false
OCR_SPLIT_GLUED_WORDS=false

# ── Vision-описания рисунков — только на индексации ──
# ── Стиль ответа: дружелюбный пересказ вместо сухой выдачи чанков ──
ANSWER_REFINE_ENABLED=true        # второй проход LLM переписывает ответ понятным языком
ANSWER_REFINE_TEMPERATURE=0.35    # чуть выше основной (0.2) для живого, но точного текста
ANSWER_REFINE_MAX_TOKENS=1024

# ── Отправка релевантных рисунков пользователю (VK) ──
SEND_FIGURES_ENABLED=true
MAX_FIGURES_PER_ANSWER=2

FIGURE_CAPTIONING_ENABLED=false
FIGURE_CAPTION_PROVIDER=none

# ── Логика выдачи (как при индексации) ──
MODEL_FILTER_STRICT=true
MODEL_STRICT_MIN_EXACT=2
CONTEXT_EXPANSION_ENABLED=true
CONTEXT_EXPANSION_WINDOW=1
CONTEXT_EXPANSION_MAX_CHARS=2400
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92

# ── Модель грузится из кэша Hugging Face. После ПЕРВОГО успешного запуска
#    (когда модель скачалась) поставьте true, чтобы не ходить в сеть. ──
HF_OFFLINE_MODE=false

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000

# ── VK Callback API (см. docs/VK_BOT_SETUP.md) ──
VK_CONFIRM_CODE=
VK_GROUP_ID=
VK_ACCESS_TOKEN=
VK_SECRET_KEY=
VK_API_VERSION=5.131
VK_ADMIN_IDS=
VK_RATE_LIMIT_PER_MINUTE=20
VK_GLOBAL_RATE_LIMIT_PER_MINUTE=120
