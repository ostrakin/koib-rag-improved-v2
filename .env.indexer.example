# ───────────────────────── KOIB RAG — пример .env ─────────────────────────
KOIB_VERSION=4.11.0

# Пути (по умолчанию относительно корня проекта)
# KOIB_DOCS_DIR=./data/docs
# KOIB_ARTIFACTS_DIR=./data/artifacts
# KOIB_OUTPUT_DIR=./output

# ── Эмбеддинги: локальная multilingual-e5-small (быстро, бесплатно) ──
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
PASSAGE_PREFIX=passage:
QUERY_PREFIX=query:
INDEXING_DEVICE=cpu               # cpu | cuda | auto
INDEXING_BATCH_SIZE=64

# ── Генерация (выберите ОДИН провайдер) ──
LLM_PROVIDER=gigachat             # gigachat | openai | local
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false
# OPENAI_API_KEY=
# OPENAI_LLM_MODEL=gpt-4o-mini
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=IlyaGusev/saiga_mistral_7b

# ── Гибридный поиск ──
VECTOR_SEARCH_K=15
BM25_SEARCH_K=10
FINAL_TOP_K=6                     # с мелкими чанками (500) берём больше фрагментов
HYBRID_ALPHA=0.6
BM25_USE_LEMMATIZATION=true
BM25_USE_STOPWORDS=true
# ── Чанкинг (требует переиндексации: ingest --rebuild) ──
TEXT_CHUNK_SIZE=500               # мельче чанк -> точнее матч; соседи дотянет Context Expansion
TEXT_CHUNK_OVERLAP=60
MIN_CHUNK_LENGTH=50
USE_RERANKER=false                # true заметно повышает точность топ-k
RERANKER_MODEL=DiTy/ru-reranker-base
USE_HYDE=false

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000

# ── VK Callback API ──
VK_CONFIRM_CODE=
VK_GROUP_ID=
VK_ACCESS_TOKEN=
VK_SECRET_KEY=
VK_API_VERSION=5.131
VK_ADMIN_IDS=
VK_RATE_LIMIT_PER_MINUTE=20
VK_GLOBAL_RATE_LIMIT_PER_MINUTE=120

# ── v4.12: предобработка OCR (Проблема 2) — тяжёлые шаги ТОЛЬКО при индексации ──
OCR_PREPROCESSING_ENABLED=true     # лёгкие замены/гомоглифы везде
OCR_DEEP_CLEAN=true                # глубокая чистка на этапе индексации
OCR_DROP_GARBAGE_LINES=true        # отсев нечитаемых строк
OCR_SPLIT_GLUED_WORDS=true         # разрезание слипшихся слов (DP-сегментация)

# ── v4.12: фильтр модели КОИБ (Проблема 4) ──
MODEL_FILTER_STRICT=true           # при ≥N точных совпадений убирать unknown
MODEL_STRICT_MIN_EXACT=2

# ── v4.12: расширение контекста при чанкинге (Проблема 5) ──
CONTEXT_EXPANSION_ENABLED=true
CONTEXT_EXPANSION_WINDOW=1          # сколько соседних text-чанков подклеивать
CONTEXT_EXPANSION_MAX_CHARS=2400

# ── v4.12: Vision-описания рисунков (Проблема 7) — ТОЛЬКО при индексации ──
FIGURE_CAPTIONING_ENABLED=false    # включать на мощной машине при сборке индекса
FIGURE_CAPTION_PROVIDER=none       # none | openai | local(Ollama)
FIGURE_CAPTION_MODEL=gpt-4o-mini
FIGURE_CAPTION_MAX_TOKENS=180
FIGURE_CAPTION_MAX_IMAGES=0         # 0 = без лимита; >0 — ограничить число вызовов

# ── v4.12: восстановление битого JSONL (Проблема 1) ──
JSONL_REPAIR_ENABLED=true
